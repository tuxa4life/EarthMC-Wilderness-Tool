# Wildness Monitor — copy to .env and fill in. The .env file is gitignored.
# Any value left blank disables the feature that needs it (fail-safe).

# ── Discord webhook (outbound alerts) ──────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
MERCENARY_ROLE_ID=YOUR_ROLE_ID

# ── Discord command bot (inbound slash commands) ───────────────────────────
DISCORD_BOT_TOKEN=YOUR_BOT_TOKEN
BOT_AUTHORIZED_USERS=YOUR_DISCORD_USER_ID,ANOTHER_USER_ID
BOT_AUTHORIZED_ROLE_ID=YOUR_AUTHORIZED_ROLE_ID
BOT_COMMAND_CHANNEL_ID=
BOT_GUILD_ID=YOUR_GUILD_ID

# ── Broadcast hub (WebSocket fan-out to game-client mods) ──────────────────
BROADCAST_ENABLED=1
BROADCAST_HOST=0.0.0.0
BROADCAST_PORT=8765
BROADCAST_TOKEN=GENERATE_A_RANDOM_SECRET
MOD_AUTHORIZED_PLAYERS=IGN1,IGN2,IGN3
